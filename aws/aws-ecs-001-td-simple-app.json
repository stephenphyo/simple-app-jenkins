{
    "requiresCompatibilities": [
      "FARGATE"
    ],
    "family": "td-simple-app",
    "containerDefinitions": [
      {
        "name": "cont-simple-app",
        "image": "356855127394.dkr.ecr.ap-southeast-1.amazonaws.com/simple-app:{VERSION}",
        "portMappings": [
          {
            "name": "http",
            "containerPort": 80,
            "hostPort": 80,
            "protocol": "tcp",
            "appProtocol": "http"
          }
        ]
      }
    ],
    "networkMode": "awsvpc",
    "volumes": [],
    "cpu": "256",
    "memory": "512",
    "executionRoleArn": "arn:aws:iam::356855127394:role/ecsTaskExecutionRole"
}